# Runtime environment: development | test | production (defaults to development).
# The simulate-send-failure dev hook is ignored when set to production.
NODE_ENV=development

# Port the API listens on
PORT=4000

# Origin allowed by CORS — the Vite dev server running the Frontend Chat MVP
FRONTEND_ORIGIN=http://localhost:5173

# Secret used to sign and verify JWT access tokens.
# Must be at least 32 characters. Generate a fresh random value per environment,
# e.g. `openssl rand -base64 48`. Never commit the real secret.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Lifetime of issued JWT access tokens, in seconds (e.g. 3600 = 1 hour)
JWT_EXPIRES_IN=3600

# Secret used to sign/verify the short-lived email-change confirmation JWT (Week 8).
# Required. Must be at least 32 characters and distinct from JWT_SECRET.
EMAIL_CHANGE_JWT_SECRET=change-me-to-a-different-long-random-secret-32-chars

# Lifetime of the email-change confirmation token, in seconds (default 1800 = 30 min).
EMAIL_CHANGE_JWT_EXPIRES_IN=1800

# AWS SES settings for the email-change confirmation email (Week 8).
# SES_REGION is optional and falls back to AWS_REGION when empty.
# SES_SOURCE_EMAIL must be a verified SES identity; required in production.
SES_REGION=
SES_SOURCE_EMAIL=no-reply@example.com

# MongoDB connection string. Use the bundled docker-compose service for local dev
# (`docker compose up -d`), or a MongoDB Atlas cluster (mongodb+srv://...).
# NOTE: the tutor / knowledge-base (RAG) feature requires Atlas — local Mongo does not
# support $vectorSearch. Direct + assistant chat work against local Mongo.
MONGO_URI=mongodb://localhost:27017/chat

# OpenAI API key for assistant mode (Week 6) + tutor answers and embeddings (Week 7).
# Required. Never commit the real key.
OPENAI_API_KEY=sk-...

# Optional (defaults shown). ASSISTANT_MODEL must be a current OpenAI model that
# supports streaming + tool calling.
ASSISTANT_MODEL=gpt-4o-mini
ASSISTANT_MAX_TOKENS=1024

# Optional (defaults shown). Week 7 RAG knowledge base.
# EMBEDDINGS_MODEL must match the Atlas vector index dimensions (1536 for -3-small).
EMBEDDINGS_MODEL=text-embedding-3-small
ATLAS_VECTOR_INDEX=knowledge_chunks_vector_index

# PRO subscription — payment provider (Week 8.2).
# PAYMENT_PROVIDER_KIND: 'rapyd' uses Rapyd hosted checkout; 'fake' is an offline,
# deterministic provider for local dev + tests (default). The RAPYD_* keys are required
# in production when PAYMENT_PROVIDER_KIND=rapyd.
PAYMENT_PROVIDER_KIND=fake
RAPYD_ACCESS_KEY=
RAPYD_SECRET_KEY=
RAPYD_BASE_URL=https://sandboxapi.rapyd.net
RAPYD_WEBHOOK_SECRET=

# PRO subscription — payment event queue (Week 8.2).
# PAYMENT_QUEUE_KIND: 'sqs' runs the background consumer against AWS SQS; 'fake' is an
# in-memory queue for local dev + tests (default). SQS_PAYMENT_QUEUE_URL is required in
# production when PAYMENT_QUEUE_KIND=sqs. The DLQ is configured on the AWS side via the
# queue's redrive policy (maxReceiveCount). AWS creds/region reuse the AWS_* vars above.
PAYMENT_QUEUE_KIND=fake
SQS_PAYMENT_QUEUE_URL=
