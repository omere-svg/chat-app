flowchart TB
    classDef ctrl fill:#dbeafe,stroke:#2563eb,color:#1e3a8a;
    classDef orch fill:#ede9fe,stroke:#7c3aed,color:#4c1d95;
    classDef svc fill:#dcfce7,stroke:#16a34a,color:#14532d;
    classDef repo fill:#fef9c3,stroke:#ca8a04,color:#713f12;
    classDef port fill:#fae8ff,stroke:#c026d3,color:#701a75;
    classDef ext fill:#f1f5f9,stroke:#475569,color:#0f172a;
    classDef help fill:#ffedd5,stroke:#ea580c,color:#7c2d12;

    Client[["HTTP client (JWT)"]]:::ext

    subgraph Controllers["controllers module"]
        AC["AvatarController (no logic)<br/>POST /me/avatar/upload-url -> AvatarUploadTicket<br/>PUT /me/avatar -> AvatarResult<br/>DELETE /me/avatar -> AvatarResult"]:::ctrl
    end

    subgraph Orchestrators["orchestrator modules (one per action)"]
        RU["request-avatar-upload<br/>prepare()"]:::orch
        SA["set-avatar<br/>confirm() -> { avatarUrl }"]:::orch
        RA["remove-avatar<br/>remove() -> { avatarUrl: null }"]:::orch
    end

    subgraph ObjStore["object-storage module (infra port)"]
        OSP{{"ObjectStorage port<br/>OBJECT_STORAGE token"}}:::port
        S3I["S3ObjectStorage impl<br/>createUploadUrl (presigned POST + size cap)<br/>headObject / deleteObject"]:::svc
        BE["deleteObjectBestEffort()"]:::help
    end

    subgraph Users["users entity module"]
        US["UsersService<br/>getUserRecord / updateAvatar / clearAvatar / toUser"]:::svc
        AUR["AvatarUrlResolver<br/>key -> https CDN url (+ ?v= cache-bust)"]:::help
        AH["avatar/ helpers<br/>buildAvatarKey = avatars/{userId}<br/>isAvatarKeyOwnedBy, constants, types"]:::help
        AE["avatar/errors/*<br/>Forbidden / NotFound / TooLarge / UnsupportedType"]:::help
        MAP["user.mapper.ts<br/>toUser(UserRecord) -> User"]:::help
        URP{{"UserRepository port<br/>USER_REPOSITORY token"}}:::port
        UMR["user.mongo.repository<br/>avatar: { srcUrl, key } | null"]:::repo
        TY["types/<br/>User, UserRecord, StoredAvatar, AvatarResult"]:::help
    end

    Env[["config: AVATAR_CDN_BASE_URL,<br/>S3 bucket, AWS creds/region"]]:::ext
    S3[("AWS S3 (private bucket)")]:::ext
    Mongo[("MongoDB - users.avatar")]:::ext

    Client --> AC
    AC --> RU
    AC --> SA
    AC --> RA

    RU --> OSP
    SA --> OSP
    SA --> US
    SA --> AUR
    RA --> OSP
    RA --> US

    OSP -. bound to .-> S3I
    S3I --> S3
    RA -. uses .-> BE
    SA -. uses .-> BE

    US --> MAP
    US --> AH
    US --> URP
    US -. throws .-> AE
    MAP --> TY
    URP -. bound to .-> UMR
    UMR --> Mongo
    AUR -. reads .-> Env
    S3I -. reads .-> Env
